config ESP_HOSTED_CP_FEAT_LIGHT_SLEEP
    bool "Light Sleep"
    depends on ESP_HOSTED_CP && PM_ENABLE
    default n
    help
        Enables automatic light sleep with PM lock management.

config ESP_HOSTED_CP_FEAT_LIGHT_SLEEP_READY
    bool
    default y if ESP_HOSTED_CP_FEAT_LIGHT_SLEEP

config ESP_HOSTED_CP_FEAT_LIGHT_SLEEP_AUTO_INIT
    bool "Auto-initialize Light Sleep at boot"
    default y
    depends on ESP_HOSTED_CP_AUTO_FEAT_INIT
    help
        When enabled, Light Sleep feature auto-initializes during eh_cp_init().
        Disable to manually call eh_cp_feat_light_sleep_init().
