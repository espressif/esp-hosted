config ESP_HOSTED_CP_FEAT_SYSTEM
    bool "System (OTA, heartbeat, FW version)"
    depends on ESP_HOSTED_CP
    default y
    help
        Enables system features: OTA update, heartbeat, FW version query, MAC address.

config ESP_HOSTED_CP_FEAT_SYSTEM_READY
    bool
    default y if ESP_HOSTED_CP_FEAT_SYSTEM

config ESP_HOSTED_CP_FEAT_SYSTEM_AUTO_INIT
    bool "Auto-initialize System at boot"
    default y
    depends on ESP_HOSTED_CP_AUTO_FEAT_INIT
    help
        When enabled, System feature auto-initializes during eh_cp_init().
        Disable to manually call eh_cp_feat_system_init().
