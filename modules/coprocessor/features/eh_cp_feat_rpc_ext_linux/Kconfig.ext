config ESP_HOSTED_CP_FEAT_RPC_LINUX
	bool
	depends on ESP_HOSTED_CP_EXT_RPC
	depends on ESP_HOSTED_CP_RPC_V1_LINUX
	default y

config ESP_HOSTED_CP_FEAT_RPC_LINUX_READY
    bool
    default y if ESP_HOSTED_CP_EXT_RPC && ESP_HOSTED_CP_RPC_V1_LINUX

config ESP_HOSTED_CP_FEAT_RPC_LINUX_AUTO_INIT
    bool "Auto-initialize RPC Linux at boot"
    default y
    depends on ESP_HOSTED_CP_AUTO_FEAT_INIT
    help
        When enabled, RPC Linux feature auto-initializes during eh_cp_init().
        Disable to manually call eh_cp_feat_rpc_ext_linux_init().
