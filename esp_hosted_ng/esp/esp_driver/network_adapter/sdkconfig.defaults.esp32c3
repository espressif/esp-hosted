CONFIG_ESP32_DEFAULT_CPU_FREQ_160=y
CONFIG_ESP32_DEFAULT_CPU_FREQ_MHZ=160
CONFIG_FREERTOS_UNICORE=y
CONFIG_SDIO_DAT2_DISABLED=

# BT Configuration
CONFIG_BT_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=y
CONFIG_BT_BLUEDROID_ENABLED=
CONFIG_BTDM_CTRL_MODE_BLE_ONLY=y
CONFIG_BTDM_CTRL_MODE_BR_EDR_ONLY=n
CONFIG_BTDM_CTRL_MODE_BTDM=n
CONFIG_BTDM_CTRL_HCI_MODE_VHCI=y

# BT over UART
# Enable below config and delete sdkconfig, build/ and rebuild for UART HCI
#CONFIG_BTDM_CTRL_HCI_MODE_UART_H4=y
#CONFIG_BTDM_CTRL_HCI_UART_NO=1
#CONFIG_BTDM_CTRL_HCI_UART_BAUDRATE=921600
#CONFIG_BTDM_CTRL_HCI_UART_FLOW_CTRL_EN=y
#CONFIG_BTDM_CTRL_HCI_UART_TX_PIN=5
#CONFIG_BTDM_CTRL_HCI_UART_RX_PIN=18
#CONFIG_BTDM_CTRL_HCI_UART_CTS_PIN=8
#CONFIG_BTDM_CTRL_HCI_UART_RTS_PIN=19

CONFIG_ESP32_WIFI_NVS_ENABLED=
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=20
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=40
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=40
CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=y
CONFIG_ESP_WIFI_TX_BA_WIN=32
CONFIG_ESP_WIFI_AMPDU_RX_ENABLED=y
CONFIG_ESP_WIFI_RX_BA_WIN=32
