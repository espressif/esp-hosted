{
  "hardware": {
    "host_port": "/dev/cu.usbserial-120",
    "slave_port": "/dev/cu.usbserial-1301",
    "board": "p4_c6_core_board",
    "flash_baud": 2000000
  },

  "wifi_ap": {
    "ssid": "Yogesh",
    "password": "PlantMoreTrees123"
  },

  "paths": {
    "idf_path": "~/esp-idf",
    "cp_base": "~/code/esp_hosted.new/fg/cp/examples/cp_mcu",
    "host_base": "~/code/esp_hosted_mcu6/examples"
  },

  "build": {
    "strategy": "fallback"
  },

  "artifacts": {
    "dir": "/tmp/esp_hosted_test_logs",
    "retention_days": 7
  },

  "suites": {
    "boot": true,
    "wifi_scan": true,
    "wifi_connect": true,
    "gpio": true,
    "peer_data": true,
    "mem_monitor": true,
    "bt": true,
    "bt_mac": true,
    "heartbeat": true,
    "ota": true
  }
}
