# ESP-Hosted coprocessor configuration
CONFIG_ESP_HOSTED=y
CONFIG_ESP_HOSTED_CP_FOR_MCU=y
# CONFIG_ESP_HOSTED_CP_FOR_LINUX__802_03 is not set
CONFIG_ESP_HOSTED_CP_RPC_V1_MCU=y

# Power Save Extension configuration
CONFIG_ESP_HOSTED_CP_FEAT_HOST_PS=y
CONFIG_ESP_HOSTED_CP_FEAT_HOST_PS_DEEP_SLEEP=y

# Host wakeup GPIO configuration (default for ESP32C6)
CONFIG_ESP_HOSTED_CP_FEAT_HOST_PS_HOST_WAKEUP_GPIO=2
CONFIG_ESP_HOSTED_CP_FEAT_HOST_PS_HOST_WAKEUP_GPIO_LEVEL_HIGH=y

# Enable full wakeup packet printing for debugging
CONFIG_ESP_HOSTED_CP_FEAT_HOST_PS_PRINT_FULL_WAKEUP_PACKET=n

# Enable CLI for power save debugging
CONFIG_ESP_HOSTED_CP_FEAT_CLI=y

# WiFi configuration
CONFIG_ESP_HOSTED_CP_FEAT_WIFI=y

# Logging configuration
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Console configuration for debugging
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200

# partitions
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_eh_cp_ota_4m.csv"
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# OS
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_WIFI_NVS_ENABLED=y

CONFIG_BOOTLOADER_COMPILER_OPTIMIZATION_PERF=y
CONFIG_COMPILER_OPTIMIZATION_PERF=y
CONFIG_ESP_CACHE_MALLOC=n
CONFIG_ESP_HOSTED_TASK_PRIORITY_DEFAULT=22
