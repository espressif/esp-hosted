# iperf config
#-------------

# Hosted config
#----------------
CONFIG_ESP_CACHE_MALLOC=y
#       --- Debugging ---
#CONFIG_ESP_HOSTED_FUNCTION_PROFILING=y
#CONFIG_ESP_PKT_STATS=y

#       --- Network split ---


# BLE disabled in this example by default
## BLE Config
##-----------
#CONFIG_BT_ENABLED=y
#CONFIG_BT_CONTROLLER_ONLY=y
#CONFIG_BT_BLUEDROID_ENABLED=
#CONFIG_BT_LE_SLEEP_ENABLE=y
#
##  --- (Opt 1) Hci over SPI/SDIO ---
##-----------------------
#CONFIG_BT_LE_HCI_INTERFACE_USE_RAM=y
#
##  --- (Opt 2) Hci over UART ---
##-------------------
## Enable below config, delete sdkconfig, build/ and rebuild
## CONFIG_BT_LE_HCI_INTERFACE_USE_UART=y


# Wifi config
#------------

CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=20
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=40
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=40
CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=y
CONFIG_ESP_WIFI_TX_BA_WIN=32
CONFIG_ESP_WIFI_AMPDU_RX_ENABLED=y
CONFIG_ESP_WIFI_RX_BA_WIN=32


# Optimizations
#-------------------
#CONFIG_LWIP_EXTRA_IRAM_OPTIMIZATION=y
CONFIG_COMPILER_OPTIMIZATION_PERF=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESP_WIFI_RX_IRAM_OPT=y
CONFIG_ESP_WIFI_IRAM_OPT=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_160=y
CONFIG_FREERTOS_PLACE_FUNCTIONS_INTO_FLASH=y
CONFIG_SPI_MASTER_ISR_IN_IRAM=n


# Partition Table
#--------------------
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_eh_cp_ota_4m.csv"
