# Host Type Configuration - Linux FG
CONFIG_ESP_HOSTED_CP_FOR_LINUX__802_03=y
# CONFIG_ESP_HOSTED_CP_FOR_MCU is not set
CONFIG_ESP_HOSTED_CP_RPC_V1_LINUX=y

CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n
# Network Split Configuration
CONFIG_ESP_HOSTED_CP_FEAT_WIFI=y
CONFIG_ESP_HOSTED_CP_FEAT_NW_SPLIT=y


# WiFi configuration
CONFIG_EXAMPLE_WIFI_SSID="myssid"
CONFIG_EXAMPLE_WIFI_PASSWORD="mypassword!123"
CONFIG_EXAMPLE_WIFI_CONN_MAX_RETRY=6
CONFIG_EXAMPLE_WIFI_AUTH_WPA2_PSK=y

## BT Configuration
#CONFIG_BT_ENABLED=y
#CONFIG_BT_CONTROLLER_ONLY=y

# OTA
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_eh_cp_ota_4m.csv"

# OS
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_WIFI_NVS_ENABLED=y

CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
CONFIG_COMPILER_OPTIMIZATION_PERF=y
