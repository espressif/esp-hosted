# Hosted config
#----------------
CONFIG_SDIO_DAT2_DISABLED=
CONFIG_ESP_CACHE_MALLOC=y
#       --- Debugging ---
#CONFIG_ESP_HOSTED_FUNCTION_PROFILING=y
#CONFIG_ESP_PKT_STATS=y

#       --- Network split ---
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y


